<div class="card report-box">
    <h2>Report a Note</h2>
    <p style="color:#888; margin-bottom:1rem; font-size:0.9rem">
        Found something suspicious? Submit a URL and our admin will review it.
    </p>
    <form method="POST" action="/report" id="reportForm">
        <input type="text" name="url" placeholder="https://..." required>
        <button type="submit">Submit to Admin</button>
    </form>
</div>
